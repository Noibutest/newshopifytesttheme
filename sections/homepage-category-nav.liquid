{%- style -%}
.category-nav-section { position: sticky; top: 0; z-index: 3; background: rgb(var(--color-background)); border-bottom: 1px solid rgba(var(--color-foreground), 0.08); }
.category-nav-section.is-sticky { box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
.category-nav__wrapper { max-width: var(--page-width); margin: 0 auto; padding: 0 1.5rem; }
.category-nav__scroll { display: flex; gap: 0.5rem; overflow-x: auto; scroll-behavior: smooth; -webkit-overflow-scrolling: touch; scrollbar-width: none; padding: 0.75rem 0; }
.category-nav__scroll::-webkit-scrollbar { display: none; }
.category-nav__item { flex-shrink: 0; display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.5rem 1rem; border-radius: 100px; font-size: 0.82rem; font-weight: 600; white-space: nowrap; text-decoration: none; color: rgb(var(--color-foreground)); background: rgba(var(--color-foreground), 0.05); border: 1px solid rgba(var(--color-foreground), 0.1); transition: all 0.15s ease; }
.category-nav__item:hover { background: rgba(var(--color-foreground), 0.1); border-color: rgba(var(--color-foreground), 0.2); }
.category-nav__item--active, .category-nav__item:active { background: rgb(var(--color-foreground)); color: rgb(var(--color-background)); border-color: rgb(var(--color-foreground)); }
.category-nav__emoji { font-size: 1rem; line-height: 1; }
.category-nav__item--search { background: rgba(var(--color-foreground), 0.08); border-color: rgba(var(--color-foreground), 0.15); }
.category-nav__item--search svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2; }
@media screen and (min-width: 750px) {
.category-nav__scroll { justify-content: center; flex-wrap: wrap; padding: 1rem 0; }
.category-nav__item { font-size: 0.85rem; padding: 0.55rem 1.2rem; }
}
{%- endstyle -%}

<div class="category-nav-section" id="CategoryNav-{{ section.id }}">
<div class="category-nav__wrapper">
<nav class="category-nav__scroll" aria-label="Shop by category">
{%- if section.settings.show_search -%}
<a href="/search" class="category-nav__item category-nav__item--search" aria-label="Search">
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
Search
</a>
{%- endif -%}
{%- for block in section.blocks -%}
<a href="{{ block.settings.link }}" class="category-nav__item" {{ block.shopify_attributes }}>
{%- unless block.settings.emoji == blank -%}
<span class="category-nav__emoji" aria-hidden="true">{{ block.settings.emoji }}</span>
{%- endunless -%}
{{ block.settings.label }}
</a>
{%- endfor -%}
</nav>
</div>
</div>

<script>
(function() {
var nav = document.getElementById('CategoryNav-{{ section.id }}');
if (!nav) return;
var observer = new IntersectionObserver(function(entries) {
nav.classList.toggle('is-sticky', !entries[0].isIntersecting);
}, { threshold: [1], rootMargin: '-1px 0px 0px 0px' });
observer.observe(nav);
})();
</script>

{% schema %}
{"name":"Category Navigation","tag":"section","class":"section-category-nav","disabled_on":{"groups":["header","footer"]},"max_blocks":15,"settings":[{"type":"checkbox","id":"show_search","label":"Show search pill","default":true}],"blocks":[{"type":"category","name":"Category","settings":[{"type":"text","id":"label","label":"Label","default":"Category"},{"type":"text","id":"emoji","label":"Emoji (optional)"},{"type":"url","id":"link","label":"Link"}]}],"presets":[{"name":"Category Navigation","blocks":[{"type":"category","settings":{"label":"Pre-Orders"}},{"type":"category","settings":{"label":"Die-Cast"}},{"type":"category","settings":{"label":"Pokemon"}},{"type":"category","settings":{"label":"Sale"}}]}]}
{% endschema %}}