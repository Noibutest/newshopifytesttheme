{%- style -%}
  .search-hero {
    padding: 1.5rem 1.5rem 0.5rem;
    text-align: center;
  }
  @media screen and (min-width: 750px) {
    .search-hero {
      padding: 2.5rem 1.5rem 1rem;
      max-width: var(--page-width);
      margin: 0 auto;
    }
  }
  .search-hero__tagline {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(var(--color-foreground), 0.5);
    margin: 0 0 0.4rem;
    font-weight: 600;
  }
  .search-hero__heading {
    margin: 0 0 1rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }
  .search-hero__form {
    position: relative;
    max-width: 540px;
    margin: 0 auto;
  }
  .search-hero__input {
    width: 100%;
    padding: 0.9rem 3rem 0.9rem 1.2rem;
    border: 2px solid rgba(var(--color-foreground), 0.15);
    border-radius: 100px;
    font-size: 0.95rem;
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    -webkit-appearance: none;
    appearance: none;
    font-family: inherit;
  }
  .search-hero__input::placeholder {
    color: rgba(var(--color-foreground), 0.4);
  }
  .search-hero__input:focus {
    border-color: rgba(var(--color-foreground), 0.4);
    box-shadow: 0 0 0 3px rgba(var(--color-foreground), 0.06);
  }
  .search-hero__submit {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: opacity 0.15s ease;
    padding: 0;
  }
  .search-hero__submit:hover {
    opacity: 0.85;
  }
  .search-hero__submit svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2.5;
  }
  .search-hero__trust {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
    font-size: 0.75rem;
    color: rgba(var(--color-foreground), 0.5);
    font-weight: 500;
  }
  .search-hero__trust-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    white-space: nowrap;
  }
  @media screen and (max-width: 749px) {
    .search-hero__trust {
      gap: 1rem;
      flex-wrap: wrap;
    }
  }
{%- endstyle -%}

<div class="search-hero color-{{ section.settings.color_scheme }}">
  {%- unless section.settings.tagline == blank -%}
    <p class="search-hero__tagline">{{ section.settings.tagline }}</p>
  {%- endunless -%}
  {%- unless section.settings.heading == blank -%}
    <h2 class="search-hero__heading {{ section.settings.heading_size }}">
      {{ section.settings.heading }}
    </h2>
  {%- endunless -%}
  <form action="{{ routes.search_url }}" method="get" role="search" class="search-hero__form">
    <input type="search" name="q" class="search-hero__input" placeholder="{{ section.settings.placeholder | escape }}" aria-label="Search products">
    <input type="hidden" name="type" value="product">
    <button type="submit" class="search-hero__submit" aria-label="Search">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </button>
  </form>
  {%- if section.settings.show_trust_badges -%}
    <div class="search-hero__trust">
      {%- for block in section.blocks -%}
        <span class="search-hero__trust-item" {{ block.shopify_attributes }}>
          {%- unless block.settings.emoji == blank -%}
            <span aria-hidden="true">{{ block.settings.emoji }}</span>
          {%- endunless -%}
          {{ block.settings.text }}
        </span>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Search Hero",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Canada's #1 Collectibles Store" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Find Your Next Grail" },
    { "type": "select", "id": "heading_size", "options": [{ "value": "h2", "label": "Small" }, { "value": "h1", "label": "Medium" }, { "value": "h0", "label": "Large" }, { "value": "hxl", "label": "Extra Large" }], "default": "h0", "label": "Heading size" },
    { "type": "text", "id": "placeholder", "label": "Search placeholder", "default": "Search die-cast, Pokemon, F1..." },
    { "type": "checkbox", "id": "show_trust_badges", "label": "Show trust badges", "default": true },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "blocks": [
    { "type": "trust_badge", "name": "Trust Badge", "settings": [
      { "type": "text", "id": "emoji", "label": "Emoji", "default": "CA" },
      { "type": "text", "id": "text", "label": "Text", "default": "Canadian Owned" }
    ]}
  ],
  "presets": [
    { "name": "Search Hero", "blocks": [
      { "type": "trust_badge", "settings": { "emoji": "CA", "text": "Canadian Owned" } },
      { "type": "trust_badge", "settings": { "emoji": "Box", "text": "Free Shipping $300+" } },
      { "type": "trust_badge", "settings": { "emoji": "Star", "text": "5-Star Reviews" } }
    ]}
  ]
}
{% endschema %}